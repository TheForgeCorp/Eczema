# Generate the key pair with: npm run gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact for push services. Use your own email or site URL.
VAPID_SUBJECT=mailto:you@example.com

# Server port (Tailscale serve proxies HTTPS to this)
PORT=3000

# Timezone for the reminder schedule
TZ=America/Toronto
