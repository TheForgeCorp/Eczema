# Generate the key pair with: npm run gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Contact for push services. Use your own email or site URL.
VAPID_SUBJECT=mailto:you@example.com

# Server port (Tailscale serve proxies HTTPS to this)
PORT=3000

# Timezone for the reminder schedule
TZ=America/Toronto

# Anthropic API key for the meal and skin analyzers (vision + reasoning).
# Get one at https://console.anthropic.com. The app runs without it; the
# analyzers stay disabled until it is set.
ANTHROPIC_API_KEY=

# Model for vision and reasoning calls. Leave as is unless you have a reason.
ANTHROPIC_MODEL=claude-opus-4-8
